@page "/admin/tenant"
@attribute [Authorize(Roles = "TenantAdmin,SuperAdmin")]
@inject NavigationManager Nav

<PageTitle>Tenant Admin — Six to Fix</PageTitle>

<div class="page-header">
    <h1 class="page-title">Tenant Admin Panel</h1>
</div>

<div class="card" style="margin-top: var(--space-6);">
    <div class="card-body empty-state">
        <p class="text-secondary">Tenant Admin Panel is coming in a future release.</p>
        <p class="text-muted" style="font-size: var(--text-sm);">
            @* TODO (Phase 5): Implement tenant admin panel.
               Features to implement:
                 - Tenant profile settings (name, slug, plan tier)
                 - User management (invite, role assignment, deactivate)
                 - HubSpot integration settings (Private App token config)
                 - Reviewer assignment configuration
                 - Audit configuration defaults (skill thresholds, policy rule overrides)
               Requires dedicated admin service methods, not yet defined. *@
            This panel allows TenantAdmins to configure their organization's settings,
            manage user roles, and set up integrations.
        </p>
    </div>
</div>

@code {
    [CascadingParameter] private Task<AuthenticationState> AuthState { get; set; } = null!;

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthState;
        if (!auth.User.Identity?.IsAuthenticated ?? true)
        {
            Nav.NavigateTo("/login", forceLoad: false);
            return;
        }
        if (!auth.User.IsInRole("TenantAdmin") && !auth.User.IsInRole("SuperAdmin"))
            Nav.NavigateTo("/audits", forceLoad: false);
    }
}
