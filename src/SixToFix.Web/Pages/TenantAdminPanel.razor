@page "/admin/tenant"
@attribute [Authorize(Roles = "TenantAdmin,SuperAdmin")]

<PageTitle>Tenant Admin — Six to Fix</PageTitle>

<div class="page-header">
    <div class="page-header-left">
        <h1 class="page-title">Tenant Admin Panel</h1>
    </div>
</div>

<div class="stat-grid">
    <div class="stat-card">
        <span class="stat-card-label">Active Users</span>
        <span class="stat-card-value">—</span>
        <span class="stat-card-sub">In this tenant</span>
    </div>
    <div class="stat-card">
        <span class="stat-card-label">Clients</span>
        <span class="stat-card-value">—</span>
        <span class="stat-card-sub">Registered</span>
    </div>
    <div class="stat-card">
        <span class="stat-card-label">Plan Tier</span>
        <span class="stat-card-value">—</span>
        <span class="stat-card-sub">Current plan</span>
    </div>
</div>

<section>
    <h2>Settings</h2>
    <div class="placeholder-section">
        @* TODO (Phase 5): Implement tenant settings — name, slug, plan tier, HubSpot token,
           reviewer assignment, skill thresholds, policy rule overrides.
           Requires dedicated admin service methods, not yet defined. *@
        <p>Tenant settings configuration is coming in Phase 5.</p>
    </div>
</section>

<section>
    <h2>User Management</h2>
    <div class="placeholder-section">
        <p>Invite users, assign roles, and deactivate accounts — coming in Phase 5.</p>
    </div>
</section>

@code {
    [CascadingParameter] private Task<AuthenticationState> AuthState { get; set; } = null!;

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthState;
        if (!auth.User.Identity?.IsAuthenticated ?? true)
            return;
    }
}