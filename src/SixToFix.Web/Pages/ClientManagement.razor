@page "/clients"
@attribute [Authorize(Roles = "TenantAdmin,SuperAdmin")]

<PageTitle>Client Management — Six to Fix</PageTitle>

<div class="page-header">
    <div class="page-header-left">
        <h1 class="page-title">Clients</h1>
    </div>
    <div class="page-header-actions">
        <button class="btn btn-primary" disabled title="IClientService not yet implemented">+ New Client</button>
    </div>
</div>

<div class="placeholder-section">
    @* TODO (Phase 5): Wire IClientService.GetClientsAsync and display real client data.
       IClientService needs: GetClientsAsync(tenantId), CreateClientAsync, UpdateClientAsync.
       Register IClientService in DI before wiring. *@
    <p class="text-muted">No clients yet. Create your first client to start an audit run.</p>
    <br />
    <button class="btn btn-secondary" disabled title="IClientService not yet implemented">Add Client</button>
</div>

@* Sample data to illustrate the intended layout *@
<section>
    <h2>Sample Layout</h2>
    <table class="table">
        <thead>
            <tr>
                <th>Client Name</th>
                <th>Slug</th>
                <th>Audit Runs</th>
                <th>Last Run</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var client in _sampleClients)
            {
                <tr class="demo-table-row">
                    <td><strong>@client.Name</strong></td>
                    <td><code>@client.Slug</code></td>
                    <td>@client.RunCount</td>
                    <td>@client.LastRun</td>
                    <td>
                        <a href="/audit-runs?clientId=@client.Id" class="btn btn-ghost btn-sm">View Audits →</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</section>

@code {
    [CascadingParameter] private Task<AuthenticationState> AuthState { get; set; } = null!;

    private readonly SampleClient[] _sampleClients =
    [
        new(Guid.NewGuid(), "Acme Corp", "acme-corp", 3, "May 8, 2025"),
        new(Guid.NewGuid(), "Northwind Traders", "northwind", 1, "May 2, 2025"),
        new(Guid.NewGuid(), "Contoso Ltd", "contoso", 0, "—")
    ];

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthState;
        if (!auth.User.Identity?.IsAuthenticated ?? true)
            return;
    }

    private sealed record SampleClient(Guid Id, string Name, string Slug, int RunCount, string LastRun);
}