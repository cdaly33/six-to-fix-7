@page "/telemetry"
@attribute [Authorize(Roles = "SuperAdmin")]

<PageTitle>Telemetry Dashboard — Six to Fix</PageTitle>

<div class="page-header">
    <div class="page-header-left">
        <h1 class="page-title">Telemetry Dashboard</h1>
    </div>
</div>

<div class="stat-grid">
    <div class="stat-card">
        <span class="stat-card-label">Audit Runs (30d)</span>
        <span class="stat-card-value">—</span>
        <span class="stat-card-sub">Platform-wide</span>
    </div>
    <div class="stat-card">
        <span class="stat-card-label">Avg Run Duration</span>
        <span class="stat-card-value">—</span>
        <span class="stat-card-sub">seconds</span>
    </div>
    <div class="stat-card">
        <span class="stat-card-label">Council Escalations</span>
        <span class="stat-card-value">—</span>
        <span class="stat-card-sub">This month</span>
    </div>
    <div class="stat-card">
        <span class="stat-card-label">AI Spend (30d)</span>
        <span class="stat-card-value">—</span>
        <span class="stat-card-sub">Estimated tokens</span>
    </div>
</div>

<section>
    <h2>Pipeline Metrics</h2>
    <div class="placeholder-section">
        @* TODO (Phase 5): Wire ITelemetryCollector.GetTelemetrySnapshotsAsync and render charts. *@
        <p>Telemetry data collection is not yet wired. Implement ITelemetryCollector in Phase 5.</p>
    </div>
</section>

@code {
    [CascadingParameter] private Task<AuthenticationState> AuthState { get; set; } = null!;

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthState;
        if (!auth.User.Identity?.IsAuthenticated ?? true)
            return;
    }
}