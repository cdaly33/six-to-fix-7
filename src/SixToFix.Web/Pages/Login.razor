@page "/login"
@layout AuthLayout
@inject SixToFix.Web.Navigation.ILoginNavigator LoginNavigator
@inject AuthenticationStateProvider AuthState
@inject IHttpClientFactory HttpFactory
@inject IJSRuntime JS

<PageTitle>Sign In — Six to Fix</PageTitle>

<div class="login-container">
    <div class="card login-card">
        <div class="card-body">
            <h1>Sign In</h1>
            <p class="text-secondary">Access your Six to Fix audit platform.</p>

            @if (_error is not null)
            {
                <div class="alert alert-error" role="alert">@_error</div>
            }

            <EditForm Model="_model" OnValidSubmit="HandleLogin" FormName="login">
                <DataAnnotationsValidator />

                <div class="form-group">
                    <label for="email">Email</label>
                    <InputText id="email" @bind-Value="_model.Email" class="form-control" type="email" autocomplete="username" />
                    <ValidationMessage For="@(() => _model.Email)" />
                </div>

                <div class="form-group">
                    <label for="password">Password</label>
                    <InputText id="password" @bind-Value="_model.Password" class="form-control" type="password" autocomplete="current-password" />
                    <ValidationMessage For="@(() => _model.Password)" />
                </div>

                <button type="submit" class="btn btn-primary btn-block" disabled="@_submitting">
                    @if (_submitting) { <span>Signing in…</span> } else { <span>Sign In</span> }
                </button>
            </EditForm>

        </div>
    </div>
</div>

@code {
    private readonly LoginModel _model = new();
    private string? _error;
    private bool _submitting;

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthState.GetAuthenticationStateAsync();
        if (auth.User.Identity?.IsAuthenticated == true)
            LoginNavigator.NavigateToDashboard();
    }

    private async Task HandleLogin()
    {
        _submitting = true;
        _error = null;
        try
        {
            var http = HttpFactory.CreateClient();
            var resp = await http.PostAsJsonAsync("/api/auth/login", new { _model.Email, _model.Password });
            if (!resp.IsSuccessStatusCode)
            {
                _error = resp.StatusCode == System.Net.HttpStatusCode.Unauthorized
                    ? "Invalid email or password."
                    : $"Login failed ({(int)resp.StatusCode}).";
                return;
            }
            var payload = await resp.Content.ReadFromJsonAsync<Dictionary<string, string>>();
            if (payload is null || !payload.TryGetValue("accessToken", out var token) || string.IsNullOrWhiteSpace(token))
            {
                _error = "No token returned.";
                return;
            }
            var persistTokenTask = JS.InvokeVoidAsync("localStorage.setItem", "six_to_fix_token", token).AsTask();
            LoginNavigator.NavigateToDashboard();
            await persistTokenTask;
        }
        catch (Exception ex)
        {
            _error = $"Unexpected error: {ex.Message}";
        }
        finally
        {
            _submitting = false;
        }
    }

    private sealed class LoginModel
    {
        [Required, EmailAddress] public string Email { get; set; } = string.Empty;
        [Required, MinLength(8)] public string Password { get; set; } = string.Empty;
    }

}