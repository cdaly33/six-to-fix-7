@page "/login"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@layout AuthLayout
@inject SixToFix.Web.Navigation.ILoginNavigator LoginNavigator
@inject AuthenticationStateProvider AuthState
@inject IJSRuntime JS

<PageTitle>Sign In — StrategyHub</PageTitle>

<div class="login-page">
    <div class="login-card">
        <div class="login-card__brand">
            <Logo Variant="light" />
        </div>

        <h1 class="login-card__heading">Sign In to StrategyHub</h1>
        <p class="login-card__sub">Access your strategic business playbook.</p>

        @if (_error is not null)
        {
            <div class="alert alert-error" role="alert">@_error</div>
        }

        <EditForm Model="_model" OnValidSubmit="HandleLogin" FormName="login">
            <DataAnnotationsValidator />

            <div class="form-group">
                <label for="email">Email</label>
                <InputText id="email" @bind-Value="_model.Email" class="form-control" type="email" autocomplete="username" />
                <ValidationMessage For="@(() => _model.Email)" />
            </div>

            <div class="form-group">
                <label for="password">Password</label>
                <InputText id="password" @bind-Value="_model.Password" class="form-control" type="password" autocomplete="current-password" />
                <ValidationMessage For="@(() => _model.Password)" />
            </div>

            <button type="submit" class="btn btn-primary btn-block" disabled="@_submitting">
                @if (_submitting) { <span>Signing in…</span> } else { <span>Sign In</span> }
            </button>
        </EditForm>
    </div>
</div>

@code {
    [SupplyParameterFromQuery(Name = "returnUrl")]
    private string? ReturnUrl { get; set; }

    private readonly LoginModel _model = new();
    private string? _error;
    private bool _submitting;

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthState.GetAuthenticationStateAsync();
        if (auth.User.Identity?.IsAuthenticated == true)
            LoginNavigator.NavigateTo(ReturnUrl);
    }

    private async Task HandleLogin()
    {
        _submitting = true;
        _error = null;
        try
        {
            var result = await JS.InvokeAsync<string>("SixToFix.login", _model.Email, _model.Password);
            switch (result)
            {
                case "ok":
                    // TODO (Phase 4): swap for a dedicated /dashboard once the playbook dashboard
                    // is built. LoginNavigator.NavigateTo already defaults to /dashboard when no
                    // returnUrl is supplied.
                    LoginNavigator.NavigateTo(ReturnUrl);
                    break;
                case "unauthorized":
                    _error = "Invalid email or password.";
                    break;
                default:
                    _error = $"Login failed ({result}).";
                    break;
            }
        }
        catch (Exception ex)
        {
            _error = $"Unexpected error: {ex.Message}";
        }
        finally
        {
            _submitting = false;
        }
    }

    private sealed class LoginModel
    {
        [Required, EmailAddress] public string Email { get; set; } = string.Empty;
        [Required, MinLength(8)] public string Password { get; set; } = string.Empty;
    }
}
