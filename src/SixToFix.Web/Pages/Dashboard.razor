@page "/dashboard"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@attribute [Authorize]
@layout StrategyHubShell
@inject IProgressService ProgressService
@inject IPillarContentService PillarContentService
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Dashboard — StrategyHub</PageTitle>

<div class="sh-dashboard">

    @* ── Header row ── *@
    <div class="sh-dashboard__header">
        <div>
            <h1 class="sh-dashboard__welcome">Welcome back, @_firstName</h1>
            <p class="sh-dashboard__sub">Continue building your strategic playbook.</p>
        </div>
        <a href="/brand" class="btn btn-gold">Resume</a>
    </div>

    @* ── Overall progress card ── *@
    <div class="sh-dashboard__progress-card">
        <div class="sh-dashboard__progress-number">@_averagePercent<span class="sh-dashboard__progress-pct">%</span></div>
        <p class="sh-dashboard__progress-label">Across all six pillars</p>
        <div class="sh-progress-bar" role="progressbar" aria-valuenow="@_averagePercent" aria-valuemin="0" aria-valuemax="100">
            <div class="sh-progress-bar__fill" style="width: @(_averagePercent)%"></div>
        </div>
    </div>

    @* ── Six pillar cards ── *@
    <h2 class="sh-dashboard__section-heading">Your Progress</h2>
    <div class="sh-pillar-grid">
        @foreach (var card in _pillarCards)
        {
            <a href="/@card.Route" class="sh-pillar-card">
                <div class="sh-pillar-card__icon-tile sh-pillar-card__icon-tile--@card.AccentKey">
                    @card.Icon
                </div>
                <div class="sh-pillar-card__body">
                    <div class="sh-pillar-card__name">@card.Name</div>
                    <div class="sh-pillar-card__tagline">@card.Tagline</div>
                    <div class="sh-pillar-card__progress-row">
                        <div class="sh-progress-bar sh-progress-bar--thin" role="progressbar" aria-valuenow="@card.Percent" aria-valuemin="0" aria-valuemax="100">
                            <div class="sh-progress-bar__fill sh-progress-bar__fill--@card.AccentKey" style="width: @(card.Percent)%"></div>
                        </div>
                        <span class="sh-pillar-card__pct">@card.Percent%</span>
                    </div>
                </div>
                <div class="sh-pillar-card__arrow" aria-hidden="true">
                    <ArrowRightIcon Size="16" />
                </div>
            </a>
        }
    </div>

    @* ── Recently updated ── *@
    <h2 class="sh-dashboard__section-heading">Recently Updated</h2>
    <div class="sh-recent-list">
        @if (_recentContent.Count == 0)
        {
            <p class="sh-recent-list__empty">—</p>
        }
        else
        {
            @foreach (var item in _recentContent)
            {
                <div class="sh-recent-list__item">
                    <span class="sh-recent-list__pillar-tag sh-pillar-tag--@item.Pillar.ToString().ToLowerInvariant()">
                        @item.Pillar
                    </span>
                    <span class="sh-recent-list__title">@(string.IsNullOrEmpty(item.Title) ? item.Pillar.ToString() : item.Title)</span>
                    <span class="sh-recent-list__date">@item.UpdatedAt.ToString("MMM d")</span>
                </div>
            }
        }
    </div>

</div>

@code {
    [CascadingParameter] private Task<AuthenticationState> AuthState { get; set; } = null!;

    private string _firstName = "there";
    private int _averagePercent;
    private List<PillarCardVm> _pillarCards = [];
    private List<PillarContent> _recentContent = [];

    private static readonly (Pillar Pillar, string Route, string AccentKey, string Name, string Tagline, RenderFragment Icon)[] PillarMeta =
    [
        (Pillar.Brand,         "brand",         "brand",         "Brand",         "Build a powerful brand identity and positioning",                               @<PaletteIcon />),
        (Pillar.Customer,      "customer",      "customer",      "Customer",      "Understand audience segments, acquisition priorities, and retention motion",    @<UsersIcon />),
        (Pillar.Offering,      "offering",      "offering",      "Offering",      "Package services for clarity, recurring revenue, and easier buying decisions",  @<BoxesIcon />),
        (Pillar.Communication, "communication", "communication", "Communication", "Deliver the right message at the right time across all channels",               @<MessageSquareIcon />),
        (Pillar.Sales,         "sales",         "sales",         "Sales",         "Turn demand into predictable revenue with clear process and follow-through",    @<TrendingUpIcon />),
        (Pillar.Management,    "management",    "management",    "Management",    "Operationalize the framework with ownership, KPIs, and execution rhythm",       @<SettingsIcon />),
    ];

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthState;
        var user = auth.User;

        if (!(user.Identity?.IsAuthenticated ?? false))
            return;

        _firstName = user.FindFirst("given_name")?.Value
                     ?? user.FindFirst(ClaimTypes.GivenName)?.Value
                     ?? (user.FindFirst("name")?.Value ?? user.FindFirst(ClaimTypes.Name)?.Value ?? "there").Split(' ')[0];

        var userIdStr = user.FindFirst(ClaimTypes.NameIdentifier)?.Value
                        ?? user.FindFirst("sub")?.Value;

        var cts = new CancellationTokenSource(TimeSpan.FromSeconds(10));

        // Always build pillar cards — progress defaults to 0 when user has no ID
        Dictionary<Pillar, int> progressDict = [];

        if (Guid.TryParse(userIdStr, out var userId))
        {
            var progressTask = ProgressService.GetForUserAsync(userId, cts.Token);
            var averageTask  = ProgressService.GetAverageForUserAsync(userId, cts.Token);
            await Task.WhenAll(progressTask, averageTask);

            _averagePercent = averageTask.Result;
            progressDict = progressTask.Result.ToDictionary(p => p.Pillar, p => p.PercentComplete);

            // Recently updated: get all pillar content for the tenant
            var tenantIdStr = user.FindFirst("tenant_id")?.Value;
            if (Guid.TryParse(tenantIdStr, out var tenantId))
            {
                var allContent = await PillarContentService.GetAllForTenantAsync(tenantId, cts.Token);
                _recentContent = allContent
                    .OrderByDescending(c => c.UpdatedAt)
                    .Take(3)
                    .ToList();
            }
        }

        _pillarCards = PillarMeta.Select(m => new PillarCardVm(
            m.Pillar, m.Route, m.AccentKey, m.Name, m.Tagline, m.Icon,
            progressDict.TryGetValue(m.Pillar, out var pct) ? pct : 0
        )).ToList();
    }

    private sealed record PillarCardVm(
        Pillar Pillar,
        string Route,
        string AccentKey,
        string Name,
        string Tagline,
        RenderFragment Icon,
        int Percent);
}

