@page "/dashboard"
@attribute [Authorize]
@inject NavigationManager Nav
<PageTitle>Dashboard — StrategyHub</PageTitle>
<div class="page-header"><div class="page-header-left"><h1 class="page-title">Dashboard</h1></div></div><div class="dashboard-grid"><div class="card dashboard-welcome"><div class="card-body"><h3>Welcome to StrategyHub</h3><p class="text-secondary">StrategyHub helps you build and execute strategy across six key pillars, delivering actionable playbooks and measurable progress.</p></div></div><a href="/pillars" class="card dashboard-nav-card"><div class="card-body"><h3 class="nav-card-title">Pillars</h3></div></a><a href="/templates" class="card dashboard-nav-card"><div class="card-body"><h3 class="nav-card-title">Templates</h3></div></a><AuthorizeView Roles="TenantAdmin,SuperAdmin"><Authorized><a href="/admin/tenant" class="card dashboard-nav-card"><div class="card-body"><h3 class="nav-card-title">Tenant Admin</h3></div></a></Authorized></AuthorizeView><AuthorizeView Roles="SuperAdmin"><Authorized><a href="/admin/super" class="card dashboard-nav-card"><div class="card-body"><h3 class="nav-card-title">Super Admin</h3></div></a></Authorized></AuthorizeView></div>
@code { [CascadingParameter] private Task<AuthenticationState> AuthState { get; set; } = null!; protected override async Task OnInitializedAsync() { var auth = await AuthState; if (!auth.User.Identity?.IsAuthenticated ?? true) Nav.NavigateTo("/login", forceLoad: false); } }
