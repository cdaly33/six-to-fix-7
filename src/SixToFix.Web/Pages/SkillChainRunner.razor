@page "/audits/{AuditRunId}/run"
@attribute [Authorize(Roles = "TenantAdmin,SuperAdmin")]
@inject NavigationManager Navigation

<PageTitle>Skill Chain Runner — Six to Fix</PageTitle>

<h1>Skill Chain Runner</h1>

@*
  TODO (Phase 4 / Architecture Decision): This page is likely superseded by AuditDetail.razor
  which shows live SignalR events from the running skill chain.
  If a separate manual trigger UI is still required:
    - Wire IAuditOrchestrator.StartAuditRunAsync(AuditRunId) to a "Start" button.
    - Display real-time skill run progress via the /hubs/audit-run SignalR hub.
  Discuss with team whether this route (/audits/{id}/run) should redirect to /audits/{id} instead.
*@

<p class="text-muted">Audit run: @AuditRunId — see <a href="/audits/@AuditRunId">Audit Detail</a> for live progress.</p>

@code {
    [Parameter] public string AuditRunId { get; set; } = string.Empty;

    [CascadingParameter] private Task<AuthenticationState> AuthState { get; set; } = null!;

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthState;
        if (!auth.User.Identity?.IsAuthenticated ?? true)
        {
            Navigation.NavigateTo("/login", forceLoad: false);
            return;
        }
        if (!auth.User.IsInRole("TenantAdmin") && !auth.User.IsInRole("SuperAdmin"))
            Navigation.NavigateTo($"/audits/{AuditRunId}", forceLoad: false);
    }
}