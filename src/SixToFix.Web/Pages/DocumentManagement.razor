@page "/documents"
@attribute [Authorize(Roles = "Reviewer,TenantAdmin,SuperAdmin")]

<PageTitle>Document Management — Six to Fix</PageTitle>

<div class="page-header">
    <div class="page-header-left">
        <h1 class="page-title">Documents</h1>
    </div>
    <div class="page-header-actions">
        <button class="btn btn-primary" disabled title="IBlobStorage not yet implemented">Upload Document</button>
    </div>
</div>

<div class="placeholder-section">
    @* TODO (Phase 5): Wire IBlobStorage.ListBlobsAsync and render document list.
       IBlobStorage needs: ListBlobsAsync, DownloadBlobAsync, UploadBlobAsync.
       Also requires Blazor InputFile component wired to upload endpoint.
       Register IBlobStorage in DI before wiring. *@
    <p class="text-muted">No documents uploaded yet. Documents provide context for AI skill analysis.</p>
</div>

<section>
    <h2>Sample Layout</h2>
    <table class="table">
        <thead>
            <tr>
                <th>File Name</th>
                <th>Type</th>
                <th>Size</th>
                <th>Uploaded</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var doc in _sampleDocs)
            {
                <tr class="demo-table-row">
                    <td>@doc.Name</td>
                    <td><span class="badge badge-info">@doc.Type</span></td>
                    <td>@doc.Size</td>
                    <td>@doc.Uploaded</td>
                    <td>
                        <button class="btn btn-ghost btn-sm" disabled>Download</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</section>

@code {
    [CascadingParameter] private Task<AuthenticationState> AuthState { get; set; } = null!;

    private readonly SampleDoc[] _sampleDocs =
    [
        new("brand-guide-2024.pdf", "PDF", "2.4 MB", "May 1, 2025"),
        new("marketing-playbook.docx", "DOCX", "1.1 MB", "Apr 28, 2025"),
        new("hubspot-export.csv", "CSV", "340 KB", "Apr 25, 2025")
    ];

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthState;
        if (!auth.User.Identity?.IsAuthenticated ?? true)
            return;
    }

    private sealed record SampleDoc(string Name, string Type, string Size, string Uploaded);
}