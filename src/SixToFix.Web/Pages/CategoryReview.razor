@page "/review/{CategoryId:guid}"
@page "/audit-runs/{RouteAuditRunId:guid}/categories/{CategoryId:guid}"
@attribute [Authorize(Roles = "Reviewer,TenantAdmin,SuperAdmin")]
@rendermode InteractiveServer
@inject IReviewerWorkflow ReviewerWorkflow
@inject NavigationManager Nav
@inject AuthenticationStateProvider AuthState
@inject ILogger<CategoryReview> Logger

<PageTitle>Category Review — Six to Fix</PageTitle>

@if (_loading)
{
    <LoadingSpinner Label="Loading category review…" />
}
else if (_error is not null)
{
    <AlertBanner Type="error" Title="Unable to load review" Message="@_error" Dismissable="false" />
}
else
{
    <PageHeader Title="Category Review" Subtitle="Review AI output, capture notes, and record the final disposition.">
        <Actions>
            @if (_auditRunId.HasValue)
            {
                <a href="/audit-runs/@_auditRunId" class="btn btn-secondary btn-sm">Back to Audit Run</a>
            }
        </Actions>
    </PageHeader>

    @if (_lockout?.IsLockedOut == true)
    {
        <AlertBanner Type="error" Title="Rejection lockout active" Message="@GetLockoutMessage()" Dismissable="false" />
    }
    else if ((_lockout?.RejectionCount ?? 0) >= 2)
    {
        <AlertBanner Type="warning" Title="Rejection warning" Message="One more rejection will trigger the 24-hour lockout for this category." Dismissable="false" />
    }

    @if (_actionError is not null)
    {
        <AlertBanner Type="error" Title="Action failed" Message="@_actionError" />
    }

    @if (_actionSuccess is not null)
    {
        <AlertBanner Type="success" Title="Review updated" Message="@_actionSuccess" />
    }

    <div class="reviewer-queue-layout">
        <div class="card">
            <div class="card-header">
                <h2>Review summary</h2>
                <StatusBadge Status="@(IsLockedOut ? "failed" : "awaiting_review")" Label="@(IsLockedOut ? "Locked" : "Awaiting decision")" />
            </div>
            <div class="card-body">
                <dl class="meta-grid">
                    <div class="meta-item">
                        <dt>Category ID</dt>
                        <dd>@CategoryId</dd>
                    </div>
                    <div class="meta-item">
                        <dt>Audit run</dt>
                        <dd>@(_auditRunId?.ToString() ?? "Unknown")</dd>
                    </div>
                    <div class="meta-item">
                        <dt>Rejections in window</dt>
                        <dd>@(_lockout?.RejectionCount ?? 0)</dd>
                    </div>
                </dl>
            </div>
        </div>

        <div class="card">
            <div class="card-header">
                <h2>AI rationale and evidence</h2>
            </div>
            <div class="card-body">
                <p class="text-secondary">The service layer does not yet expose category evidence text directly, so this drawer preserves the review workflow shell without duplicating business logic.</p>
                <div class="placeholder-section">
                    <p>Evidence and narrative will render here once a category detail query is added by the service layer.</p>
                </div>
            </div>
        </div>

        <div class="card">
            <div class="card-header">
                <h2>Reviewer comments</h2>
            </div>
            <div class="card-body">
                <div class="form-group">
                    <label class="form-label" for="review-comments">Comments</label>
                    <InputTextArea id="review-comments" class="form-control" @bind-Value="_comments" />
                    <div class="page-subtitle">Comments are used as the rejection reason when you reject this category.</div>
                </div>
                <div class="page-header-actions">
                    <button class="btn btn-primary" @onclick="ApproveAsync" disabled="@(_busy || IsLockedOut)">Approve</button>
                    <button class="btn btn-danger" @onclick="RejectAsync" disabled="@(_busy || IsLockedOut)">Reject</button>
                    <button class="btn btn-secondary" @onclick="EscalateAsync" disabled="@(_busy || IsLockedOut)">Escalate</button>
                    <button class="btn btn-ghost" @onclick="RerunAsync" disabled="@(_busy || IsLockedOut)">Rerun</button>
                </div>
            </div>
        </div>

        @if (_council is not null)
        {
            <div class="card">
                <div class="card-header">
                    <h2>Council result</h2>
                    <StatusBadge Status="completed" Label="Decision returned" />
                </div>
                <div class="card-body">
                    <p><strong>Decision:</strong> @_council.DecisionType</p>
                    <p><strong>Confidence:</strong> @_council.OverallConfidence.ToString("P0")</p>
                    <p class="text-secondary">@_council.Rationale</p>
                </div>
            </div>
        }
    </div>
}

@code {
    [Parameter] public Guid CategoryId { get; set; }
    [Parameter] public Guid? RouteAuditRunId { get; set; }
    [SupplyParameterFromQuery] private Guid? AuditRunId { get; set; }

    private ReviewerLockoutStatus? _lockout;
    private CouncilDecisionModel? _council;
    private Guid? _auditRunId;
    private Guid _reviewerId;
    private bool _loading;
    private bool _busy;
    private string? _error;
    private string? _actionError;
    private string? _actionSuccess;
    private string _comments = string.Empty;

    private bool IsLockedOut => _lockout?.IsLockedOut == true;

    protected override async Task OnInitializedAsync()
    {
        _auditRunId = RouteAuditRunId ?? AuditRunId;
        _loading = true;

        try
        {
            var auth = await AuthState.GetAuthenticationStateAsync();
            var userIdStr = auth.User.FindFirst(ClaimTypes.NameIdentifier)?.Value;
            if (!Guid.TryParse(userIdStr, out _reviewerId))
            {
                _error = "Could not identify the current reviewer.";
                return;
            }

            if (!_auditRunId.HasValue)
            {
                _error = "An audit run ID is required to review this category.";
                return;
            }

            _lockout = await ReviewerWorkflow.GetLockoutStatusAsync(_auditRunId.Value, CategoryId, _reviewerId);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load category review {CategoryId}", CategoryId);
            _error = "The category review could not be loaded.";
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task ApproveAsync()
    {
        if (!_auditRunId.HasValue) return;
        await RunActionAsync(async () =>
        {
            await ReviewerWorkflow.ApproveAsync(_auditRunId.Value, CategoryId, _reviewerId);
            _actionSuccess = "Category approved.";
        });
    }

    private async Task RejectAsync()
    {
        if (!_auditRunId.HasValue) return;
        await RunActionAsync(async () =>
        {
            await ReviewerWorkflow.RejectAsync(_auditRunId.Value, CategoryId, _reviewerId, _comments);
            _actionSuccess = "Category rejected.";
            _lockout = await ReviewerWorkflow.GetLockoutStatusAsync(_auditRunId.Value, CategoryId, _reviewerId);
        });
    }

    private async Task RerunAsync()
    {
        if (!_auditRunId.HasValue) return;
        await RunActionAsync(async () =>
        {
            await ReviewerWorkflow.RerunAsync(_auditRunId.Value, CategoryId, _reviewerId);
            _actionSuccess = "Rerun requested. Watch the audit detail screen for live progress.";
        });
    }

    private async Task EscalateAsync()
    {
        if (!_auditRunId.HasValue) return;
        await RunActionAsync(async () =>
        {
            _council = await ReviewerWorkflow.EscalateAsync(_auditRunId.Value, CategoryId, _reviewerId);
            _actionSuccess = "Escalated to the council.";
        });
    }

    private async Task RunActionAsync(Func<Task> action)
    {
        _busy = true;
        _actionError = null;
        _actionSuccess = null;

        try
        {
            await action();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Reviewer action failed for category {CategoryId}", CategoryId);
            _actionError = ex.Message;
        }
        finally
        {
            _busy = false;
        }
    }

    private string GetLockoutMessage()
    {
        if (_lockout?.LockoutExpiresAt is null)
        {
            return "This category cannot be rejected again until the lockout window resets.";
        }

        return $"This category is locked until {_lockout.LockoutExpiresAt.Value.LocalDateTime:MMM d, h:mm tt}.";
    }
}
