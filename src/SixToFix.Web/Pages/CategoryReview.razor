@page "/review/{CategoryId}"
@attribute [Authorize(Roles = "Reviewer,TenantAdmin,SuperAdmin")]
@inject NavigationManager Navigation

<PageTitle>Category Review — Six to Fix</PageTitle>

<h1>Category Review</h1>
@* Full implementation — Phase 4 *@
<p class="text-muted">Under construction. Category: @CategoryId</p>

@code {
    [Parameter] public string CategoryId { get; set; } = string.Empty;

    [CascadingParameter] private Task<AuthenticationState> AuthState { get; set; } = null!;

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthState;
        if (!auth.User.Identity?.IsAuthenticated ?? true)
        {
            Navigation.NavigateTo("/login", forceLoad: false);
            return;
        }
        if (!auth.User.IsInRole("Reviewer") && !auth.User.IsInRole("TenantAdmin") && !auth.User.IsInRole("SuperAdmin"))
        {
            Navigation.NavigateTo("/audits", forceLoad: false);
        }
    }
}
