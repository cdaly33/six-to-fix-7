@page "/onboard"
@attribute [Authorize(Roles = "TenantAdmin,SuperAdmin")]
@inject NavigationManager Nav

<PageTitle>Tenant Onboarding — Six to Fix</PageTitle>

<div class="page-header">
    <h1 class="page-title">Tenant Onboarding</h1>
</div>

<div class="card" style="margin-top: var(--space-6);">
    <div class="card-body empty-state">
        <p class="text-secondary">Tenant Onboarding wizard is coming in a future release.</p>
        <p class="text-muted" style="font-size: var(--text-sm);">
            @* TODO (Phase 5): Implement tenant onboarding wizard.
               Step 1: Create first client (name, slug, HubSpot company ID link).
               Step 2: Connect HubSpot (verify Private App token via IHubSpotClient).
               Step 3: Upload reference documents via IBlobStorage.
               Step 4: Configure skill thresholds and Policy Engine rules.
               Step 5: Start first audit run via IAuditOrchestrator.CreateAuditRunAsync.
               Implement as a multi-step wizard using a step enum and conditional rendering. *@
            The onboarding wizard will guide you through setting up your first client,
            connecting HubSpot, uploading documents, and running your first audit.
        </p>
        <a href="/clients" class="btn btn-primary">Go to Client Management</a>
    </div>
</div>

@code {
    [CascadingParameter] private Task<AuthenticationState> AuthState { get; set; } = null!;

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthState;
        if (!auth.User.Identity?.IsAuthenticated ?? true)
        {
            Nav.NavigateTo("/login", forceLoad: false);
            return;
        }
        if (!auth.User.IsInRole("TenantAdmin") && !auth.User.IsInRole("SuperAdmin"))
            Nav.NavigateTo("/audits", forceLoad: false);
    }
}
