@page "/calibration"
@attribute [Authorize(Roles = "TenantAdmin,SuperAdmin")]

<PageTitle>Calibration Dashboard — Six to Fix</PageTitle>

<div class="page-header">
    <div class="page-header-left">
        <h1 class="page-title">Calibration Dashboard</h1>
    </div>
</div>

<div class="stat-grid">
    <div class="stat-card">
        <span class="stat-card-label">Calibration Sessions</span>
        <span class="stat-card-value">0</span>
        <span class="stat-card-sub">Total recorded</span>
    </div>
    <div class="stat-card">
        <span class="stat-card-label">Avg Score Delta</span>
        <span class="stat-card-value">—</span>
        <span class="stat-card-sub">vs. baseline</span>
    </div>
    <div class="stat-card">
        <span class="stat-card-label">Last Calibration</span>
        <span class="stat-card-value">—</span>
        <span class="stat-card-sub">No data yet</span>
    </div>
</div>

<section>
    <h2>Calibration History</h2>
    <div class="placeholder-section">
        @* TODO (Phase 5): Wire ICalibrationTracker.GetCalibrationSummaryAsync and display delta rows. *@
        <p>No calibration sessions recorded. Run an audit and compare scores to establish a baseline.</p>
    </div>
</section>

@code {
    [CascadingParameter] private Task<AuthenticationState> AuthState { get; set; } = null!;

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthState;
        if (!auth.User.Identity?.IsAuthenticated ?? true)
            return;
    }
}