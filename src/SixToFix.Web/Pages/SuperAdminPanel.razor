@page "/admin/super"
@attribute [Authorize(Roles = "SuperAdmin")]

<PageTitle>Super Admin — Six to Fix</PageTitle>

<div class="page-header">
    <div class="page-header-left">
        <h1 class="page-title">Super Admin Panel</h1>
    </div>
</div>

<div class="stat-grid">
    <div class="stat-card">
        <span class="stat-card-label">Total Tenants</span>
        <span class="stat-card-value">—</span>
        <span class="stat-card-sub">Platform-wide</span>
    </div>
    <div class="stat-card">
        <span class="stat-card-label">Total Users</span>
        <span class="stat-card-value">—</span>
        <span class="stat-card-sub">All tenants</span>
    </div>
    <div class="stat-card">
        <span class="stat-card-label">Active Runs</span>
        <span class="stat-card-value">—</span>
        <span class="stat-card-sub">Right now</span>
    </div>
</div>

<section>
    <h2>Tenant Management</h2>
    <div class="placeholder-section">
        @* TODO (Phase 5): Wire ITenantAdminService.GetAllTenantsAsync() and ITenantAdminService.ImpersonateTenantAsync().
           SuperAdmin is the only role that may access cross-tenant data.
           Use careful authorization checks — never expose one tenant's data to another. *@
        <p>Cross-tenant management tools coming in Phase 5.</p>
    </div>
</section>

<section>
    <h2>Platform Metrics</h2>
    <div class="placeholder-section">
        <p>Platform-wide metrics coming in a future release.</p>
    </div>
</section>

@code {
    [CascadingParameter] private Task<AuthenticationState> AuthState { get; set; } = null!;

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthState;
        if (!auth.User.Identity?.IsAuthenticated ?? true)
            return;
    }
}
