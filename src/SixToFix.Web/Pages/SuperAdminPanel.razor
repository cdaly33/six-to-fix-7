@page "/admin/super"
@attribute [Authorize(Roles = "SuperAdmin")]
@inject NavigationManager Navigation

<PageTitle>Super Admin — Six to Fix</PageTitle>

<h1>Super Admin Panel</h1>

@*
  TODO (Phase 4): Implement super admin panel.
  Requires cross-tenant service paths not yet defined, such as:
    - ITenantAdminService.GetAllTenantsAsync() → IReadOnlyList<Tenant>
    - ITenantAdminService.ImpersonateTenantAsync(Guid tenantId) (or similar)
    - ITelemetryCollector.GetGlobalMetricsAsync() for platform-wide telemetry
  SuperAdmin role is the only role that should access cross-tenant data.
  Use careful authorization checks — never expose one tenant's data to another.
*@

<p class="text-muted">Super admin tools coming in Phase 4.</p>

@code {
    [CascadingParameter] private Task<AuthenticationState> AuthState { get; set; } = null!;

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthState;
        if (!auth.User.Identity?.IsAuthenticated ?? true)
        {
            Navigation.NavigateTo("/login", forceLoad: false);
            return;
        }
        if (!auth.User.IsInRole("SuperAdmin"))
            Navigation.NavigateTo("/audits", forceLoad: false);
    }
}