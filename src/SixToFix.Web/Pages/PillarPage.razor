@page "/brand"
@page "/customer"
@page "/offering"
@page "/communication"
@page "/sales"
@page "/management"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@attribute [Authorize]
@layout StrategyHubShell
@inject IPillarContentService PillarContentService
@inject IProgressService ProgressService
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Nav

<PageTitle>@_pillarTitle — StrategyHub</PageTitle>

<div class="sh-pillar-page">

    @* ── Header ── *@
    <div class="sh-pillar-page__header sh-pillar-page__header--@_accentKey">
        <div class="sh-pillar-page__header-left">
            <div class="sh-pillar-page__icon-tile sh-pillar-card__icon-tile--@_accentKey">
                @_icon
            </div>
            <div>
                <div class="sh-pillar-page__ordinal">PILLAR @_pillarOrdinal OF 6</div>
                <div class="sh-pillar-page__header">
    <h1 class="sh-pillar-page__title">@_pillarTitle</h1>
    <div class="sh-pillar-page__header-right">
        <AuthorizeView Roles="SuperAdmin,TenantAdmin">
            <Authorized>
                <a href="/admin/content?pillar=@_accentKey" class="sh-pillar-page__edit-btn">Edit content</a>
            </Authorized>
        </AuthorizeView>
    </div>
</div>

                <p class="sh-pillar-page__subtitle">@_subtitle</p>
            </div>
        </div>
    </div>

    @* ── Tabs ── *@
    <div class="sh-tabs">
        @foreach (var tab in _tabs)
        {
            <button class="sh-tabs__tab @(tab == _activeTab ? "sh-tabs__tab--active" : "")"
                    @onclick="() => _activeTab = tab">
                @TabLabel(tab)
            </button>
        }
    </div>

    @if (IsUsingStarterContent(_activeTab))
    {
        <div class="sh-pillar-page__starter-note">
            <p class="sh-pillar-page__starter-text">
                Starter guidance is shown until custom tenant content is added.
            </p>
            <AuthorizeView Roles="SuperAdmin,TenantAdmin">
                <Authorized>
                    <a href="/admin/content?pillar=@_accentKey" class="btn btn-sm btn-secondary">Customize Content</a>
                </Authorized>
            </AuthorizeView>
        </div>
    }

    @* ── Tab content ── *@
    <div class="sh-pillar-page__content">
        @if (_loading)
        {
            <p class="sh-pillar-page__loading">Loading content…</p>
        }
        else
        {
            @if (_activeTab == "strategy")
            {
                <div class="sh-strategy-grid">
                    @foreach (var block in GetStrategyContent())
                    {
                        <div class="sh-strategy-block">
                            <h3 class="sh-strategy-block__title">@block.Title</h3>
                            <ul class="sh-strategy-block__points">
                                @foreach (var point in block.Points)
                                {
                                    <li class="sh-strategy-block__point">
                                        <span class="sh-strategy-block__check" aria-hidden="true">✓</span>
                                        @point
                                    </li>
                                }
                            </ul>
                        </div>
                    }
                </div>
            }

            @if (_activeTab == "execution")
            {
                <div class="sh-execution-grid">
                    @for (int i = 0; i < GetExecutionContent().Count; i++)
                    {
                        var step = GetExecutionContent()[i];
                        var num = i + 1;
                        <div class="sh-execution-step">
                            <div class="sh-execution-step__num">@num</div>
                            <div class="sh-execution-step__text">@step</div>
                        </div>
                    }
                </div>
            }

            @if (_activeTab == "templates")
            {
                <div class="sh-template-grid">
                    @foreach (var item in GetTemplateContent())
                    {
                        <div class="sh-template-item">
                            <div class="sh-template-item__icon">
                                <ClipboardIcon Size="20" />
                            </div>
                            <div class="sh-template-item__name">@item</div>
                        </div>
                    }
                </div>
            }

            @if (_activeTab == "examples")
            {
                <ul class="sh-examples-list">
                    @foreach (var ex in GetExampleContent())
                    {
                        <li class="sh-examples-list__item">@ex</li>
                    }
                </ul>
            }

            @if (_activeTab == "metrics")
            {
                <div class="sh-metrics-grid">
                    @foreach (var (label, value) in GetMetricContent())
                    {
                        <div class="sh-metric-card">
                            <div class="sh-metric-card__label">@label</div>
                            <div class="sh-metric-card__value">@value</div>
                        </div>
                    }
                </div>
            }
        }
    </div>

    @* ── Mark Progress ── *@
    <div class="sh-pillar-page__mark-progress">
        <p class="sh-pillar-page__mark-label">Mark your progress on this pillar:</p>
        <div class="sh-progress-buttons">
            @foreach (var pct in new[] { 25, 50, 75, 100 })
            {
                <button class="btn btn-sm @(_currentProgress == pct ? "btn-progress-active" : "btn-secondary")"
                        @onclick="() => MarkProgressAsync(pct)"
                        disabled="@_savingProgress">
                    @pct%
                </button>
            }
        </div>
        @if (_progressSaved)
        {
            <span class="sh-pillar-page__saved">✓ Saved</span>
        }
    </div>

</div>

@code {
    private static readonly string[] _tabs = ["strategy", "execution", "templates", "examples", "metrics"];

    private Pillar _pillarEnum;
    private string _accentKey = string.Empty;
    private string _pillarTitle = string.Empty;
    private string _subtitle = string.Empty;
    private int _pillarOrdinal;
    private RenderFragment? _icon;
    private string _activeTab = "strategy";
    private bool _loading = true;
    private bool _savingProgress;
    private bool _progressSaved;
    private int _currentProgress;

    private List<StrategyBlock> _strategy = [];
    private List<string> _execution = [];
    private List<string> _templateItems = [];
    private List<string> _examples = [];
    private List<(string Label, string Value)> _metrics = [];

    private Guid _userId;
    private Guid _tenantId;

    private static readonly Dictionary<Pillar, StarterContent> StarterContentByPillar = new()
    {
        [Pillar.Brand] = new(
            [new("Positioning Foundation", ["Define your ICP and differentiation in one sentence.", "Align brand promise to measurable business outcomes."]), new("Narrative Clarity", ["Audit website and pitch language for consistency.", "Map top objections and prepare proof points."])],
            ["Document tone and visual standards used in sales assets.", "Update hero message across website and onboarding emails.", "Publish quarterly brand health review with owners."],
            ["Brand Messaging Matrix", "Value Proposition One-Pager", "Proof Library Checklist"],
            ["Before/after homepage headline rewrite improved demo requests.", "Brand voice guide reduced proposal revision cycles."],
            [("Branded search growth", "↑ 12% QoQ"), ("Win-rate on ideal-fit opportunities", "≥ 35%"), ("Message consistency score", "Target 90%+")]
        ),
        [Pillar.Customer] = new(
            [new("Segment Strategy", ["Define top customer segments by revenue potential.", "Prioritize the segment with shortest time-to-value."]), new("Journey Design", ["Map onboarding and renewal touchpoints.", "Assign owners for every stage of the lifecycle."])],
            ["Score current pipeline by segment and urgency.", "Interview 5 recent customers to capture buying triggers.", "Implement one retention play for at-risk accounts."],
            ["Customer Interview Guide", "Journey Mapping Worksheet", "Renewal Risk Tracker"],
            ["Segment-specific onboarding cut implementation time.", "Retention outreach playbook recovered expansion opportunities."],
            [("NPS by segment", "Track monthly"), ("Time to first value", "< 30 days"), ("Retention rate", "Target 92%+")]
        ),
        [Pillar.Offering] = new(
            [new("Offer Architecture", ["Bundle services into 2-3 clear packages.", "Define outcomes, scope, and boundaries per package."]), new("Pricing Confidence", ["Standardize pricing guardrails for margin protection.", "Clarify when discounts require approval."])],
            ["List all deliverables and remove low-value custom work.", "Publish package comparison sheet for sales calls.", "Pilot one premium tier with expansion path."],
            ["Service Packaging Canvas", "Scope Definition Checklist", "Pricing Approval Matrix"],
            ["Offer simplification reduced proposal cycle time.", "Tiered packaging increased average deal size."],
            [("Average deal size", "↑ 15%"), ("Gross margin per package", "Target 55%+"), ("Proposal-to-close time", "< 21 days")]
        ),
        [Pillar.Communication] = new(
            [new("Channel Focus", ["Select 2 primary channels for demand generation.", "Set message intent by channel and funnel stage."]), new("Content Rhythm", ["Create repeatable weekly publishing cadence.", "Tie each content asset to a CTA and KPI."])],
            ["Audit last 60 days of campaigns and remove low performers.", "Launch one nurture sequence by lifecycle stage.", "Define response SLA for inbound leads."],
            ["Campaign Brief Template", "Content Calendar", "CTA Performance Tracker"],
            ["Lifecycle email sequence improved MQL-to-SQL conversion.", "Channel simplification improved message recall."],
            [("Engagement rate", "Target 5%+"), ("MQL to SQL conversion", "Target 30%+"), ("Inbound response time", "< 2 hours")]
        ),
        [Pillar.Sales] = new(
            [new("Pipeline Discipline", ["Create stage definitions with clear exit criteria.", "Track conversion at every stage weekly."]), new("Deal Velocity", ["Standardize discovery and proposal cadence.", "Flag stalled deals with recovery actions."])],
            ["Implement call scorecard for first meetings.", "Create a weekly deal review ritual with action owners.", "Build objection-handling snippets in CRM."],
            ["Discovery Call Framework", "Pipeline Review Agenda", "Objection Handling Playbook"],
            ["Structured deal reviews lifted close rates.", "New qualification criteria reduced late-stage churn."],
            [("Qualified pipeline coverage", "3x target"), ("Stage conversion rate", "Improve 10%"), ("Average sales cycle", "Reduce by 20%")]
        ),
        [Pillar.Management] = new(
            [new("Operating Cadence", ["Establish weekly KPI review with accountable owners.", "Use one source of truth for strategic priorities."]), new("Execution Visibility", ["Convert goals into 90-day milestones.", "Track blockers and decisions transparently."])],
            ["Define top 5 KPIs and owners for the quarter.", "Run a monthly strategy health checkpoint.", "Document escalations and decisions within 24 hours."],
            ["Quarterly Planning Template", "KPI Owner Scorecard", "Decision Log"],
            ["Weekly scorecard reviews improved accountability.", "Clear milestone tracking reduced cross-team blockers."],
            [("On-time milestone completion", "Target 90%+"), ("Weekly KPI update rate", "100%"), ("Cross-team blocker resolution", "< 5 business days")]
        )
    };

    private static readonly (Pillar Pillar, string Route, string AccentKey, string OrdinalLabel, string DefaultSubtitle, RenderFragment Icon)[] AllPillars =
    [
        (Pillar.Brand,         "brand",         "brand",         "1", "Build a powerful brand identity and positioning",                             @<PaletteIcon />),
        (Pillar.Customer,      "customer",      "customer",      "2", "Understand audience segments, acquisition priorities, and retention motion",  @<UsersIcon />),
        (Pillar.Offering,      "offering",      "offering",      "3", "Package services for clarity, recurring revenue, and easier buying decisions",@<BoxesIcon />),
        (Pillar.Communication, "communication", "communication", "4", "Deliver the right message at the right time across all channels",             @<MessageSquareIcon />),
        (Pillar.Sales,         "sales",         "sales",         "5", "Turn demand into predictable revenue with clear process and follow-through",  @<TrendingUpIcon />),
        (Pillar.Management,    "management",    "management",    "6", "Operationalize the framework with ownership, KPIs, and execution rhythm",     @<SettingsIcon />),
    ];

    protected override async Task OnInitializedAsync()
    {
        try
        {
            // Resolve pillar from current URL
            var segment = Nav.ToBaseRelativePath(Nav.Uri).Split('?')[0].Trim('/').ToLowerInvariant();
            var meta = AllPillars.FirstOrDefault(p => p.Route == segment);
            if (meta == default)
            {
                Nav.NavigateTo("/dashboard");
                return;
            }

            _pillarEnum   = meta.Pillar;
            _accentKey    = meta.AccentKey;
            _pillarTitle  = meta.Pillar.ToString() + " Strategy";
            _subtitle     = meta.DefaultSubtitle;
            _pillarOrdinal = (int)meta.Pillar;
            _icon         = meta.Icon;

            // Auth
            var auth = await AuthStateProvider.GetAuthenticationStateAsync();
            var user = auth.User;
            if (!(user.Identity?.IsAuthenticated ?? false)) return;

            Guid.TryParse(user.FindFirst(ClaimTypes.NameIdentifier)?.Value ?? user.FindFirst("sub")?.Value, out _userId);
            Guid.TryParse(user.FindFirst("tenant_id")?.Value, out _tenantId);

            using var cts = new CancellationTokenSource(TimeSpan.FromSeconds(10));

            // Load content
            if (_tenantId != Guid.Empty)
            {
                var content = await PillarContentService.GetForTenantAsync(_tenantId, _pillarEnum, cts.Token);
                if (content is not null)
                {
                    if (!string.IsNullOrEmpty(content.Title)) _pillarTitle = content.Title;
                    if (!string.IsNullOrEmpty(content.Subtitle)) _subtitle = content.Subtitle;
                    ParseBodyJson(content.BodyJson);
                }
            }

            // Load current progress
            if (_userId != Guid.Empty)
            {
                var progress = await ProgressService.GetForUserPillarAsync(_userId, _pillarEnum, cts.Token);
                _currentProgress = progress?.PercentComplete ?? 0;
            }
        }
        catch
        {
            // Fall back to starter content if tenant data services fail.
        }
        finally
        {
            _loading = false;
        }
    }

    private IReadOnlyList<StrategyBlock> GetStrategyContent() =>
        _strategy.Count > 0 ? _strategy : StarterContentByPillar[_pillarEnum].Strategy;

    private IReadOnlyList<string> GetExecutionContent() =>
        _execution.Count > 0 ? _execution : StarterContentByPillar[_pillarEnum].Execution;

    private IReadOnlyList<string> GetTemplateContent() =>
        _templateItems.Count > 0 ? _templateItems : StarterContentByPillar[_pillarEnum].Templates;

    private IReadOnlyList<string> GetExampleContent() =>
        _examples.Count > 0 ? _examples : StarterContentByPillar[_pillarEnum].Examples;

    private IReadOnlyList<(string Label, string Value)> GetMetricContent() =>
        _metrics.Count > 0 ? _metrics : StarterContentByPillar[_pillarEnum].Metrics;

    private bool IsUsingStarterContent(string tab) => tab switch
    {
        "strategy" => _strategy.Count == 0,
        "execution" => _execution.Count == 0,
        "templates" => _templateItems.Count == 0,
        "examples" => _examples.Count == 0,
        "metrics" => _metrics.Count == 0,
        _ => false
    };

    private void ParseBodyJson(string bodyJson)
    {
        if (string.IsNullOrWhiteSpace(bodyJson) || bodyJson == "{}") return;

        try
        {
            var doc = System.Text.Json.JsonDocument.Parse(bodyJson);
            var root = doc.RootElement;

            if (root.TryGetProperty("placeholder", out var ph) && ph.GetBoolean()) return;

            if (root.TryGetProperty("strategy", out var stratEl) && stratEl.ValueKind == System.Text.Json.JsonValueKind.Array)
            {
                foreach (var block in stratEl.EnumerateArray())
                {
                    var title = block.TryGetProperty("title", out var t) ? t.GetString() ?? "" : "";
                    var points = new List<string>();
                    if (block.TryGetProperty("points", out var pts) && pts.ValueKind == System.Text.Json.JsonValueKind.Array)
                    {
                        foreach (var p in pts.EnumerateArray())
                        {
                            var point = p.GetString();
                            if (!string.IsNullOrWhiteSpace(point)) points.Add(point);
                        }
                    }

                    if (!string.IsNullOrWhiteSpace(title) || points.Count > 0)
                    {
                        _strategy.Add(new StrategyBlock(title, points));
                    }
                }
            }

            if (root.TryGetProperty("execution", out var execEl) && execEl.ValueKind == System.Text.Json.JsonValueKind.Array)
            {
                foreach (var item in execEl.EnumerateArray())
                {
                    var value = item.GetString();
                    if (!string.IsNullOrWhiteSpace(value)) _execution.Add(value);
                }
            }

            if (root.TryGetProperty("templates", out var tplEl) && tplEl.ValueKind == System.Text.Json.JsonValueKind.Array)
            {
                foreach (var item in tplEl.EnumerateArray())
                {
                    var value = item.GetString();
                    if (!string.IsNullOrWhiteSpace(value)) _templateItems.Add(value);
                }
            }

            if (root.TryGetProperty("examples", out var exEl) && exEl.ValueKind == System.Text.Json.JsonValueKind.Array)
            {
                foreach (var item in exEl.EnumerateArray())
                {
                    var value = item.GetString();
                    if (!string.IsNullOrWhiteSpace(value)) _examples.Add(value);
                }
            }

            if (root.TryGetProperty("metrics", out var metEl) && metEl.ValueKind == System.Text.Json.JsonValueKind.Array)
            {
                foreach (var pair in metEl.EnumerateArray())
                {
                    if (pair.ValueKind == System.Text.Json.JsonValueKind.Array)
                    {
                        var arr = pair.EnumerateArray().ToArray();
                        if (arr.Length >= 2)
                        {
                            var label = arr[0].GetString() ?? string.Empty;
                            var value = arr[1].GetString() ?? string.Empty;
                            if (!string.IsNullOrWhiteSpace(label) && !string.IsNullOrWhiteSpace(value))
                            {
                                _metrics.Add((label, value));
                            }
                        }
                    }
                }
            }
        }
        catch
        {
            // Malformed JSON — leave lists empty; empty state messages will render.
        }
    }

    private async Task MarkProgressAsync(int percent)
    {
        if (_userId == Guid.Empty) return;
        _savingProgress = true;
        _progressSaved  = false;
        try
        {
            var cts = new CancellationTokenSource(TimeSpan.FromSeconds(5));
            await ProgressService.SetPercentAsync(_userId, _pillarEnum, percent, cts.Token);
            _currentProgress = percent;
            _progressSaved = true;
            StateHasChanged();
            await Task.Delay(2000);
            _progressSaved = false;
        }
        finally
        {
            _savingProgress = false;
        }
    }

    private static string TabLabel(string tab) => tab switch
    {
        "strategy"  => "Strategy",
        "execution" => "Execution Blueprint",
        "templates" => "Templates",
        "examples"  => "Examples",
        "metrics"   => "Metrics",
        _ => tab
    };

    private sealed record StrategyBlock(string Title, List<string> Points);
    private sealed record StarterContent(
        IReadOnlyList<StrategyBlock> Strategy,
        IReadOnlyList<string> Execution,
        IReadOnlyList<string> Templates,
        IReadOnlyList<string> Examples,
        IReadOnlyList<(string Label, string Value)> Metrics);
}
