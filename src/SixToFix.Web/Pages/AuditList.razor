@page "/audits"
@page "/audit-runs"
@attribute [Authorize]
@rendermode InteractiveServer
@inject IAuditOrchestrator AuditOrchestrator
@inject NavigationManager Nav
@inject ILogger<AuditList> Logger

<PageTitle>Audit Runs — Six to Fix</PageTitle>

<div class="page-header">
    <div class="page-header-left">
        <h1 class="page-title">Audit Runs</h1>
        @if (_clientId.HasValue)
        {
            <span class="text-secondary">Client @_clientId</span>
        }
    </div>
    <AuthorizeView Roles="TenantAdmin,SuperAdmin">
        <Authorized>
            @if (_clientId.HasValue)
            {
                <button class="btn btn-primary" @onclick="StartNewRun">+ New Audit Run</button>
            }
        </Authorized>
    </AuthorizeView>
</div>

@if (!_clientId.HasValue)
{
    <div class="alert alert-error">
        <strong>No client selected.</strong> Navigate here from a client page — a <code>clientId</code> query parameter is required.
    </div>
}
else if (_loading)
{
    <LoadingSpinner Label="Loading audit runs…" />
}
else if (_error is not null)
{
    <div class="alert alert-error">@_error</div>
}
else if (_runs.Count == 0)
{
    <div class="empty-state">
        <p>No audit runs found for this client.</p>
        <AuthorizeView Roles="TenantAdmin,SuperAdmin">
            <Authorized>
                <button class="btn btn-primary" @onclick="StartNewRun">Create First Audit Run</button>
            </Authorized>
        </AuthorizeView>
    </div>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>Started</th>
                <th>Status</th>
                <th>Score</th>
                <th>Tier</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var run in _runs)
            {
                <tr>
                    <td>@run.StartedAt.LocalDateTime.ToString("MMM d, yyyy h:mm tt")</td>
                    <td><AuditStatusChip Status="@run.Status" /></td>
                    <td>
                        @if (run.CompositeScore.HasValue)
                        {
                            <strong>@run.CompositeScore.Value</strong>
                        }
                        else
                        {
                            <span class="text-muted">—</span>
                        }
                    </td>
                    <td>
                        @if (run.Tier is not null)
                        {
                            <TierBadge Tier="@run.Tier" />
                        }
                        else
                        {
                            <span class="text-muted">—</span>
                        }
                    </td>
                    <td>
                        <a href="/audit-runs/@run.Id" class="btn btn-ghost btn-sm">View →</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    [SupplyParameterFromQuery] private Guid? ClientId { get; set; }

    private Guid? _clientId;
    private List<AuditRun> _runs = [];
    private bool _loading;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        _clientId = ClientId;
        if (!_clientId.HasValue) return;

        _loading = true;
        try
        {
            var results = await AuditOrchestrator.GetAuditRunsForClientAsync(_clientId.Value);
            _runs = [.. results.OrderByDescending(r => r.StartedAt)];
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load audit runs for client {ClientId}", _clientId);
            _error = "Failed to load audit runs.";
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task StartNewRun()
    {
        // TODO: requires authenticated userId from auth state; IAuditOrchestrator.CreateAuditRunAsync then redirect
        await Task.CompletedTask;
        Logger.LogWarning("StartNewRun not yet wired — needs userId from auth state");
    }
}