@page "/"
@layout PublicLayout

<PageTitle>StrategyHub — Your Complete Business Playbook</PageTitle>
<HeadContent>
    <meta name="description" content="Transform strategy into execution with personalized playbooks covering every dimension of business growth." />
</HeadContent>

<section class="hero" aria-labelledby="hero-heading">
    <div class="hero__inner">
        <div class="hero__badge animate-fade-slide-up" aria-label="Platform type">
            STRATEGIC BUSINESS PLATFORM
        </div>

        <h1 id="hero-heading" class="hero__heading animate-fade-slide-up animate-delay-1">
            Your Complete <span class="hero__accent">Business Playbook</span>
        </h1>

        <p class="hero__sub animate-fade-slide-up animate-delay-2">
            Transform strategy into execution with personalized playbooks covering every dimension of business growth.
        </p>

        <div class="hero__cta-wrap animate-fade-slide-up animate-delay-3">
            <a href="/login" class="public-btn-gold public-btn-gold--lg">
                Start Your Playbook
                <ArrowRightIcon Size="20" />
            </a>
        </div>
    </div>
</section>

<section class="pillars" aria-labelledby="pillars-heading">
    <div class="pillars__intro">
        <h2 id="pillars-heading" class="pillars__heading">Six Pillars of Business Strategy</h2>
        <p class="pillars__sub">
            A comprehensive framework covering every strategic dimension your business needs to thrive.
        </p>
    </div>

    <div class="pillar-grid">
        <a href="/login" class="pillar-card" aria-label="Brand Strategy">
            <div class="pillar-card__icon-tile pillar-card__icon-tile--brand">
                <PaletteIcon Size="24" />
            </div>
            <h3 class="pillar-card__name">Brand Strategy</h3>
            <p class="pillar-card__desc">Define your brand identity, positioning, and value proposition.</p>
        </a>

        <a href="/login" class="pillar-card" aria-label="Customer Strategy">
            <div class="pillar-card__icon-tile pillar-card__icon-tile--customer">
                <UsersIcon Size="24" />
            </div>
            <h3 class="pillar-card__name">Customer Strategy</h3>
            <p class="pillar-card__desc">Understand audience segments, ideal customers, and buyer personas.</p>
        </a>

        <a href="/login" class="pillar-card" aria-label="Offering Strategy">
            <div class="pillar-card__icon-tile pillar-card__icon-tile--offering">
                <BoxesIcon Size="24" />
            </div>
            <h3 class="pillar-card__name">Offering Strategy</h3>
            <p class="pillar-card__desc">Craft compelling products and service portfolios with recurring value.</p>
        </a>

        <a href="/login" class="pillar-card" aria-label="Communication Strategy">
            <div class="pillar-card__icon-tile pillar-card__icon-tile--communication">
                <MessageSquareIcon Size="24" />
            </div>
            <h3 class="pillar-card__name">Communication Strategy</h3>
            <p class="pillar-card__desc">Build messaging frameworks and content systems across channels.</p>
        </a>

        <a href="/login" class="pillar-card" aria-label="Sales Strategy">
            <div class="pillar-card__icon-tile pillar-card__icon-tile--sales">
                <TrendingUpIcon Size="24" />
            </div>
            <h3 class="pillar-card__name">Sales Strategy</h3>
            <p class="pillar-card__desc">Design sales processes, pipeline visibility, and revenue growth plans.</p>
        </a>

        <a href="/login" class="pillar-card" aria-label="Management Strategy">
            <div class="pillar-card__icon-tile pillar-card__icon-tile--management">
                <SettingsIcon Size="24" />
            </div>
            <h3 class="pillar-card__name">Management Strategy</h3>
            <p class="pillar-card__desc">Establish execution rhythm, scorecards, and operational alignment.</p>
        </a>
    </div>
</section>
