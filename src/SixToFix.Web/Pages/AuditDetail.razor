@page "/audits/{AuditRunId}"
@attribute [Authorize]
@inject NavigationManager Navigation

<PageTitle>Audit Detail — Six to Fix</PageTitle>

<h1>Audit Detail</h1>
@* Full implementation — Phase 4 *@
<p class="text-muted">Under construction. Audit run: @AuditRunId</p>

@code {
    [Parameter] public string AuditRunId { get; set; } = string.Empty;

    [CascadingParameter] private Task<AuthenticationState> AuthState { get; set; } = null!;

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthState;
        if (!auth.User.Identity?.IsAuthenticated ?? true)
        {
            Navigation.NavigateTo("/login", forceLoad: false);
        }
    }
}
