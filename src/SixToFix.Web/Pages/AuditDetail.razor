@page "/audits/{AuditRunId:guid}"
@page "/audit-runs/{AuditRunId:guid}"
@attribute [Authorize]
@rendermode InteractiveServer
@implements IDisposable
@inject IAuditOrchestrator AuditOrchestrator
@inject IReviewerWorkflow ReviewerWorkflow
@inject IPublisher Publisher
@inject NavigationManager Nav
@inject AuthenticationStateProvider AuthState
@inject ILogger<AuditDetail> Logger

<PageTitle>Audit Detail — Six to Fix</PageTitle>

@if (_loading)
{
    <LoadingSpinner Label="Loading audit run…" />
}
else if (_error is not null)
{
    <div class="alert alert-error">@_error</div>
}
else if (_run is not null)
{
    <div class="page-header">
        <div class="page-header-left">
            <a href="/audit-runs" class="btn btn-ghost btn-sm">← Audit Runs</a>
            <h1 class="page-title">Audit Run</h1>
        </div>
        <div class="page-header-actions">
            @if (_polling)
            {
                <StatusDot Status="connected" Label="Live" />
            }
            <AuthorizeView Roles="TenantAdmin,SuperAdmin">
                <Authorized>
                    @if (_run.Status == "completed" && _publishResult is null)
                    {
                        <button class="btn btn-primary" @onclick="PublishAsync" disabled="@_publishing">
                            @(_publishing ? "Publishing…" : "Publish Results")
                        </button>
                    }
                </Authorized>
            </AuthorizeView>
        </div>
    </div>

    <div class="meta-grid">
        <div class="meta-item"><span class="label">Status</span> <AuditStatusChip Status="@_run.Status" /></div>
        <div class="meta-item"><span class="label">Started</span> @_run.StartedAt.LocalDateTime.ToString("MMM d, yyyy h:mm tt")</div>
        @if (_run.CompletedAt.HasValue)
        {
            <div class="meta-item"><span class="label">Completed</span> @_run.CompletedAt.Value.LocalDateTime.ToString("MMM d, yyyy h:mm tt")</div>
        }
        @if (_run.CompositeScore.HasValue)
        {
            <div class="meta-item"><span class="label">Composite Score</span> <strong>@_run.CompositeScore.Value</strong></div>
        }
        @if (_run.Tier is not null)
        {
            <div class="meta-item"><span class="label">Tier</span> <TierBadge Tier="@_run.Tier" /></div>
        }
    </div>

    @if (_publishResult is not null)
    {
        <div class="alert alert-success">
            Published! Tier: <strong>@_publishResult.Tier</strong> — Score: <strong>@_publishResult.CompositeScore</strong>
        </div>
    }

    @if (_run.CategoryResults.Count > 0)
    {
        <h2>Category Results</h2>
        <div>
            @foreach (var cat in _run.CategoryResults.OrderBy(c => c.Category))
            {
                <div class="category-result-row">
                    <div class="category-result-info">
                        <ScoreCard Category="@cat.Category" Score="@cat.ActivityScore" Status="@cat.Status" />
                    </div>
                    <div class="category-result-actions">
                        <a href="/audit-runs/@AuditRunId/categories/@cat.Id" class="btn btn-ghost btn-sm">Review →</a>
                    </div>
                </div>
            }
        </div>
    }

    @if (_run.ErrorMessage is not null)
    {
        <div class="alert alert-error"><strong>Run failed:</strong> @_run.ErrorMessage</div>
    }
}

@code {
    [Parameter] public Guid AuditRunId { get; set; }

    private AuditRun? _run;
    private bool _loading;
    private string? _error;
    private bool _publishing;
    private PublishResult? _publishResult;
    private bool _polling;
    private PeriodicTimer? _pollTimer;
    private readonly CancellationTokenSource _cts = new();

    protected override async Task OnInitializedAsync()
    {
        _loading = true;
        try
        {
            _run = await AuditOrchestrator.GetAuditRunAsync(AuditRunId);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load audit run {AuditRunId}", AuditRunId);
            _error = "Failed to load audit run.";
        }
        finally
        {
            _loading = false;
        }

        if (_run is not null && _run.Status is "running" or "pending")
            _ = StartPollingAsync();
    }

    private async Task StartPollingAsync()
    {
        _pollTimer = new PeriodicTimer(TimeSpan.FromSeconds(3));
        _polling = true;
        try
        {
            while (await _pollTimer.WaitForNextTickAsync(_cts.Token))
            {
                try
                {
                    _run = await AuditOrchestrator.GetAuditRunAsync(AuditRunId);
                }
                catch (Exception ex)
                {
                    Logger.LogWarning(ex, "Poll failed for audit run {AuditRunId}", AuditRunId);
                }

                await InvokeAsync(StateHasChanged);

                if (_run?.Status is "completed" or "awaiting_review" or "failed") break;
            }
        }
        catch (OperationCanceledException) { }
        finally
        {
            _polling = false;
        }
    }

    private async Task PublishAsync()
    {
        _publishing = true;
        try
        {
            var auth = await AuthState.GetAuthenticationStateAsync();
            var userIdStr = auth.User.FindFirst(ClaimTypes.NameIdentifier)?.Value;
            if (!Guid.TryParse(userIdStr, out var userId)) { _error = "Could not identify current user."; return; }
            _publishResult = await Publisher.PublishAuditAsync(AuditRunId, userId);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to publish audit run {AuditRunId}", AuditRunId);
            _error = "Publish failed.";
        }
        finally
        {
            _publishing = false;
        }
    }

    public void Dispose()
    {
        _cts.Cancel();
        _pollTimer?.Dispose();
        _cts.Dispose();
    }
}