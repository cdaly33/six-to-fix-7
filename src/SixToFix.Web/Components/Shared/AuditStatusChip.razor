@* Displays audit run status as a colored badge. *@

<span class="badge @GetBadgeClass()" role="status">
    @Status
</span>

@code {
    /// <summary>Audit run status (pending | running | completed | failed).</summary>
    [Parameter, EditorRequired] public string Status { get; set; } = string.Empty;

    private string GetBadgeClass() => Status switch
    {
        "completed" => "badge-success",
        "running"   => "badge-info",
        "failed"    => "badge-error",
        _           => "badge-warning"
    };
}
