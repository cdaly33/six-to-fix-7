@* Dismissable alert banner. *@
@if (_visible)
{
    <div class="alert-banner alert-@Type" role="alert" aria-live="polite">
        <span class="alert-banner-icon" aria-hidden="true">@GetIcon()</span>
        <div class="alert-banner-body">
            @if (!string.IsNullOrEmpty(Title))
            {
                <div class="alert-banner-title">@Title</div>
            }
            <div class="alert-banner-message">@Message</div>
        </div>
        @if (Dismissable)
        {
            <button class="alert-banner-close" @onclick="Dismiss" aria-label="Dismiss">✕</button>
        }
    </div>
}

@code {
    [Parameter, EditorRequired] public string Message { get; set; } = string.Empty;
    [Parameter] public string Title { get; set; } = string.Empty;
    [Parameter] public string Type { get; set; } = "info"; // success | error | warning | info
    [Parameter] public bool Dismissable { get; set; } = true;

    private bool _visible = true;

    private void Dismiss() => _visible = false;

    private string GetIcon() => Type switch
    {
        "success" => "✅",
        "error"   => "❌",
        "warning" => "⚠️",
        _         => "ℹ️"
    };
}