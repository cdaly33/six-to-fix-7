@inject NavigationManager Nav

<header class="top-nav" role="banner">
    <div class="top-nav-left">
        <button class="top-nav-toggle btn btn-ghost btn-sm" type="button" @onclick="OnToggleSidebar" aria-label="Toggle navigation">☰</button>
        <div class="top-nav-title-group">
            <div class="breadcrumb">
                <span class="breadcrumb-item">@PrimaryCrumb</span>
                @if (!string.Equals(PrimaryCrumb, CurrentTitle, StringComparison.Ordinal))
                {
                    <span class="breadcrumb-sep">/</span>
                    <span class="breadcrumb-item">@CurrentTitle</span>
                }
            </div>
            <div class="top-nav-page-title">@CurrentTitle</div>
        </div>
        <AuthorizeView>
            <Authorized Context="authState">
                @{
                    var tenantSlug = authState.User.FindFirst("tenant_slug")?.Value;
                }
                @if (!string.IsNullOrEmpty(tenantSlug))
                {
                    <span class="top-nav-tenant" aria-label="Current tenant">@tenantSlug</span>
                }
            </Authorized>
        </AuthorizeView>
    </div>
    <div class="top-nav-right">
        <AuthorizeView>
            <Authorized Context="authState">
                @{
                    var userName = authState.User.Identity?.Name ?? string.Empty;
                }
                <span class="top-nav-avatar" aria-hidden="true" title="@userName">@GetInitials(userName)</span>
                <span class="top-nav-user">@userName</span>
                <a class="btn btn-ghost btn-sm" href="/logout" aria-label="Sign out">Sign out</a>
            </Authorized>
        </AuthorizeView>
    </div>
</header>

@code {
    [Parameter] public EventCallback OnToggleSidebar { get; set; }

    private string CurrentTitle => GetBreadcrumbs().LastOrDefault() ?? "Dashboard";
    private string PrimaryCrumb => GetBreadcrumbs().FirstOrDefault() ?? "Dashboard";

    private IEnumerable<string> GetBreadcrumbs()
    {
        var path = Nav.ToBaseRelativePath(Nav.Uri).Split('?', '#')[0].Trim('/');
        if (string.IsNullOrWhiteSpace(path))
        {
            return ["Dashboard"];
        }

        return path.Split('/', StringSplitOptions.RemoveEmptyEntries)
            .Where(segment => !Guid.TryParse(segment, out _))
            .Select(MapSegment)
            .DefaultIfEmpty("Dashboard");
    }

    private static string MapSegment(string segment) => segment.ToLowerInvariant() switch
    {
        "dashboard" => "Dashboard",
        "pillars" => "Pillars",
        "templates" => "Templates",
        "admin" => "Admin",
        "tenant" => "Tenant Admin",
        "super" => "Super Admin",
        _ => string.Join(' ', segment.Split('-', StringSplitOptions.RemoveEmptyEntries).Select(UpperFirst))
    };
    private static string UpperFirst(string value) => string.IsNullOrWhiteSpace(value) ? value : char.ToUpperInvariant(value[0]) + value[1..];

    private static string GetInitials(string name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "?";
        var parts = name.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return parts.Length >= 2
            ? $"{char.ToUpperInvariant(parts[0][0])}{char.ToUpperInvariant(parts[^1][0])}"
            : char.ToUpperInvariant(parts[0][0]).ToString();
    }
}

