@* Role-filtered sidebar navigation. Roles per role-visibility-matrix.md. *@

<nav class="nav-menu @(_collapsed ? "sidebar-collapsed" : "")" aria-label="Main navigation">
    <div class="nav-header">
        <div class="nav-brand">
            <span class="nav-logo" aria-hidden="true">◆</span>
            <span class="nav-title">Six to Fix</span>
        </div>
        <button class="nav-toggle" @onclick="ToggleCollapsed"
                aria-label="@(_collapsed ? "Expand sidebar" : "Collapse sidebar")"
                title="@(_collapsed ? "Expand" : "Collapse")">
            @(_collapsed ? "▶" : "◀")
        </button>
    </div>

    <ul class="nav-list" role="list">
        <li>
            <NavLink class="nav-link" href="/dashboard" Match="NavLinkMatch.All">
                <span class="nav-icon" aria-hidden="true">🏠</span>
                <span class="nav-label">Dashboard</span>
            </NavLink>
        </li>
        <li>
            <NavLink class="nav-link" href="/audit-runs" Match="NavLinkMatch.Prefix">
                <span class="nav-icon" aria-hidden="true">📋</span>
                <span class="nav-label">Audit Runs</span>
            </NavLink>
        </li>
        <li>
            <AuthorizeView Roles="Reviewer,TenantAdmin,SuperAdmin">
                <Authorized>
                    <NavLink class="nav-link" href="/reviewer-queue" Match="NavLinkMatch.Prefix">
                        <span class="nav-icon" aria-hidden="true">✓</span>
                        <span class="nav-label">Review Queue</span>
                    </NavLink>
                </Authorized>
            </AuthorizeView>
        </li>
        <li>
            <AuthorizeView Roles="TenantAdmin,SuperAdmin">
                <Authorized>
                    <NavLink class="nav-link" href="/clients" Match="NavLinkMatch.Prefix">
                        <span class="nav-icon" aria-hidden="true">👥</span>
                        <span class="nav-label">Clients</span>
                    </NavLink>
                </Authorized>
            </AuthorizeView>
        </li>
        <li>
            <AuthorizeView Roles="Reviewer,TenantAdmin,SuperAdmin">
                <Authorized>
                    <NavLink class="nav-link" href="/documents" Match="NavLinkMatch.Prefix">
                        <span class="nav-icon" aria-hidden="true">📁</span>
                        <span class="nav-label">Documents</span>
                    </NavLink>
                </Authorized>
            </AuthorizeView>
        </li>
        <li>
            <AuthorizeView Roles="TenantAdmin,SuperAdmin">
                <Authorized>
                    <NavLink class="nav-link" href="/calibration" Match="NavLinkMatch.Prefix">
                        <span class="nav-icon" aria-hidden="true">⚡</span>
                        <span class="nav-label">Calibration</span>
                    </NavLink>
                </Authorized>
            </AuthorizeView>
        </li>
        <li>
            <AuthorizeView Roles="SuperAdmin">
                <Authorized>
                    <NavLink class="nav-link" href="/telemetry" Match="NavLinkMatch.Prefix">
                        <span class="nav-icon" aria-hidden="true">📊</span>
                        <span class="nav-label">Telemetry</span>
                    </NavLink>
                </Authorized>
            </AuthorizeView>
        </li>
    </ul>

    <div class="nav-footer">
        <AuthorizeView Roles="TenantAdmin,SuperAdmin">
            <Authorized>
                <NavLink class="nav-link" href="/admin/tenant" Match="NavLinkMatch.Prefix">
                    <span class="nav-icon" aria-hidden="true">⚙️</span>
                    <span class="nav-label">Tenant Admin</span>
                </NavLink>
            </Authorized>
        </AuthorizeView>
        <AuthorizeView Roles="SuperAdmin">
            <Authorized>
                <NavLink class="nav-link" href="/admin/super" Match="NavLinkMatch.Prefix">
                    <span class="nav-icon" aria-hidden="true">🔑</span>
                    <span class="nav-label">Super Admin</span>
                </NavLink>
            </Authorized>
        </AuthorizeView>
    </div>
</nav>

@code {
    [Parameter] public EventCallback<bool> OnCollapsedChanged { get; set; }

    private bool _collapsed;

    private async Task ToggleCollapsed()
    {
        _collapsed = !_collapsed;
        await OnCollapsedChanged.InvokeAsync(_collapsed);
    }
}